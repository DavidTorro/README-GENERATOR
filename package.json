{
  "name": "readme-generator",
  "version": "0.1.0",
  "description": "Generador de README.md para tus proyectos. Crea un README.md profesional y atractivo para tu proyecto de manera rápida y sencilla.",
  "keywords": ["readme", "generator", "cli", "ollama", "documentation"],
  "license": "",
  "author": {
    "name": "David Torró",
    "url": "https://davidtorro.es"
  },
  "type": "module",
  "bin": {
    "readme-gen": "dist/cli.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
