{
  "name": "@davidtorro/readme-gen",
  "version": "0.1.4",
  "description": "Generate polished README.md files from local project analysis with optional Ollama AI enrichment and Mermaid architecture diagrams.",
  "keywords": [
    "readme-generator",
    "readme",
    "documentation",
    "cli",
    "ollama",
    "mermaid",
    "developer-tools",
    "project-scanner"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "David Torró",
    "url": "https://davidtorro.es"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavidTorro/README-GENERATOR.git"
  },
  "bugs": {
    "url": "https://github.com/DavidTorro/README-GENERATOR/issues"
  },
  "homepage": "https://readme-gen.davidtorro.com",
  "type": "module",
  "bin": {
    "readme-gen": "dist/main.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc",
    "test": "vitest run",
    "verify": "npm run typecheck && npm test && npm run build",
    "prepublishOnly": "npm run verify",
    "cli": "npm run build && node dist/main.js",
    "docs:dev": "vitepress dev website",
    "docs:build": "vitepress build website",
    "docs:preview": "vitepress preview website"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "fast-glob": "^3.3.3"
  }
}
